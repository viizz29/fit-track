{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "outDir": "dist",
    "deleteOutDir": true,
    "assets": ["assets/mail-templates/**/*.hbs"],
    "watchAssets": true,
    "plugins": ["@nestjs/swagger"]
  }
}
