APP_ENV=local
NODE_ENV=local
PORT=3000
API_BASE_URL=/api
DOCS_URL=/docs
SOCKETIO_ENDPOINT=/ws
SOCKETIO_ENDPOINT_ON=false

JWT_SECRET=replace-with-a-long-secret

DB_HOST=127.0.0.1
DB_DATABASE=fitrack
DB_USERNAME=postgres
DB_PASSWORD=postgres

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=your-redis-password

PUBLIC_HOST_WITH_PORT=http://localhost:3000
FRONTEND_BUILD_PATH=public
VERIFICATION_TOKEN_EXPIRY_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1
OTP_EXPIRY_MINUTES=10

SCHEDULED_TASKS_ENABLED=false
ENABLE_NOTIFICATION_EMAILS=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USERNAME=yourusername@gmail.com
SMTP_PASSWORD=your-app-password

MAIL_FROM_ADDRESS=yourusername@gmail.com
MAIL_FROM_NAME=Fit Track
