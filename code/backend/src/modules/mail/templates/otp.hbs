<html>

  <head>
    <meta charset='utf-8' />
    <title>Your Verification Code</title>
  </head>

  <body
    style='font-family: Arial, Helvetica, sans-serif; background:#f4f4f4; padding:40px;'
  >

    <table
      style='max-width:600px;background:white;margin:auto;padding:40px;border-radius:8px;'
    >
      <tr>
        <td>

          <h2>Hello {{name}},</h2>

          <p>
            Your verification code is:
          </p>

          <div
            style='
                    text-align:center;
                    font-size:34px;
                    font-weight:bold;
                    letter-spacing:8px;
                    margin:30px 0;
                    color:#2563eb;
                '
          >
            {{otp}}
          </div>

          <p>
            This code expires in
            <strong>{{expiryMinutes}} minutes</strong>.
          </p>

          <p>
            If you didn't request this code, you can safely ignore this email.
          </p>

        </td>
      </tr>
    </table>

  </body>

</html>