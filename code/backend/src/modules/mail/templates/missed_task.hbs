<html>

  <head>
    <meta charset='utf-8' />
    <title>Missed Exercise Notification</title>
  </head>

  <body
    style='font-family: Arial, Helvetica, sans-serif; background:#f4f4f4; padding:40px;'
  >

    <table
      style='max-width:600px;background:white;margin:auto;padding:40px;border-radius:8px;'
    >
      <tr>
        <td>

          <h2>Hello {{name}},</h2>

          <p>
            It looks like you missed a scheduled exercise. Don't worry, just
            get back on track!
          </p>

          <div
            style='
                    background:#fef3f2;
                    border-left:4px solid #ef4444;
                    padding:16px 20px;
                    margin:20px 0;
                    border-radius:4px;
                '
          >
            <p style='margin:0 0 8px 0; font-weight:bold; color:#991b1b;'>
              {{task_name}}
            </p>
            {{#if task_description}}
              <p style='margin:0; color:#444;'>
                {{task_description}}
              </p>
            {{/if}}
          </div>

          <p>
            Every step counts. Whenever you're ready, jump back in!
          </p>

          <p style='color:#999; font-size:13px; margin-top:30px;'>
            You received this because you have email notifications enabled.
          </p>

        </td>
      </tr>
    </table>

  </body>

</html>